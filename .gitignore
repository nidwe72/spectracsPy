
# screen-gallery harness output (regenerable)
.gallery/

# Python bytecode caches (regenerable)
__pycache__/
*.py[cod]

# Android build artifacts (multi-GB, regenerable) — keep only the source scaffolds
# (android/patch_p4a.sh, android/spike/{main.py,buildozer.spec,README.md})
android/spike/.buildozer/
android/spike/bin/
android/spike/wheels/
android/spike/app_src/
android/spike/deployment/
android/spike/*.apk
android/spike/pysidedeploy.spec
android/tooling-venv/
# android/server: track buildozer.spec + patch_server_p4a.sh; ignore build artifacts + staged sources
android/server/.buildozer/
android/server/bin/
android/server/app_src/
android/server/*.apk

# Claude Code machine-local settings (personal; not shared)
.claude/settings.local.json
# Stray camera capture probe (debug artifact)
camera_capture_probe.png
captureDiagnostics/

